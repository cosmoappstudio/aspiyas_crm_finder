# LeadRadar Backend — Ortam değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (backend için)
# veya SUPABASE_ANON_KEY=eyJ... (sadece public tablolar için)

# Apollo.io (B3)
APOLLO_API_KEY=xxx

# Serper (önerilen — 150+ sonuç için. Yoksa DuckDuckGo/Bing ~40-50 döner)
# SERPER_API_KEY=xxx
